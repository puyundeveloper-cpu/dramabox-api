            <div class="nb-flat inline-block px-6 py-4 mb-4" style="box-shadow: 4px 4px 0px var(--line); background: #fff;">
                <p class="font-extrabold text-sm mb-1">Dramabox API v1.2.0</p>
                <p class="text-black/50 text-xs font-semibold">Developed by <span style="color: var(--c-blue-d);">Yun</span> &middot; <span class="mono">t.me/q_sra</span></p>
            </div>
            <br>
            <a href="https://whatsapp.com/channel/0029VbD9rcnB4hdIw6JKcp1P" target="_blank"
                class="btn-nb inline-flex" style="background: var(--c-mint);">
                <i class="fa-brands fa-whatsapp"></i> Hubungi Kami
            </a>
        </div>
